# 应用配置
APP_NAME="BTC Options Trading System"
APP_VERSION="1.0.0"
ENVIRONMENT="development"

# API服务配置
API_HOST="0.0.0.0"
API_PORT=8000
API_DEBUG=true

# Deribit API配置
# 
# 情绪交易系统配置说明：
# - 主网API用于收集真实市场数据（可选）
# - 测试网API用于执行交易下单（必需）
# 
# 如果只配置测试网密钥，系统将使用测试网数据和测试网交易
# 如果同时配置主网和测试网，系统将使用主网数据但在测试网下单

# 主网配置（用于收集真实市场数据 - 可选）
DERIBIT_MAINNET_API_KEY=""
DERIBIT_MAINNET_API_SECRET=""

# 测试网配置（用于交易下单 - 必需）
DERIBIT_TESTNET_API_KEY=""
DERIBIT_TESTNET_API_SECRET=""

# 兼容旧配置（如果没有上面的分离配置，将使用这个作为测试网密钥）
DERIBIT_API_KEY=""
DERIBIT_API_SECRET=""

# 测试网配置（用于开发和测试）
# DERIBIT_TEST_MODE=true
# DERIBIT_BASE_URL="https://test.deribit.com"
# DERIBIT_WS_URL="wss://test.deribit.com/ws/api/v2"

# 生产网配置（用于真实市场数据）
DERIBIT_TEST_MODE=false
DERIBIT_BASE_URL="https://www.deribit.com"
DERIBIT_WS_URL="wss://www.deribit.com/ws/api/v2"
DERIBIT_RATE_LIMIT=20
DERIBIT_RATE_WINDOW=1
DERIBIT_MAX_RETRIES=3
DERIBIT_RETRY_DELAY=1.0

# 数据库配置
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="btc_options"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"

REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""

INFLUXDB_HOST="localhost"
INFLUXDB_PORT=8086
INFLUXDB_TOKEN=""
INFLUXDB_ORG="btc-options"
INFLUXDB_BUCKET="market-data"

# 交易配置
DEFAULT_CURRENCY="BTC"
RISK_FREE_RATE=0.05
MAX_PORTFOLIO_DELTA=100.0
MAX_PORTFOLIO_GAMMA=50.0
MAX_PORTFOLIO_VEGA=1000.0
MAX_PORTFOLIO_VALUE=1000000
MAX_SINGLE_POSITION=100000
DEFAULT_INITIAL_CAPITAL=100000
COMMISSION_RATE=0.001

# CORS配置
CORS_ORIGINS=["http://localhost:3000"]
CORS_METHODS=["GET", "POST", "PUT", "DELETE"]

# JWT配置
JWT_SECRET_KEY="your-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=30

# 日志配置
LOG_LEVEL="INFO"
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE_PATH="logs/app.log"
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# ── Vol Strategy（波动率捕捉策略，独立账户）────────────────────────────────
# 与 sentiment_trading_service 和 weighted_sentiment 完全隔离

# Deribit 独立账户（在 Deribit Test 新建一个账户）
VOL_STRATEGY_DERIBIT_API_KEY=""
VOL_STRATEGY_DERIBIT_API_SECRET=""
VOL_STRATEGY_TESTNET="true"          # true=测试网, false=主网

# 信号过滤（可选，有默认值）
VOL_STRATEGY_NEWS_SCORE_MIN="7"      # 新闻评分门槛
VOL_STRATEGY_DVOL_RANK_MAX="40"      # IV Rank 上限（超过此值不开仓）
VOL_STRATEGY_CONFIDENCE_MIN="60"     # 综合置信度下限

# 交易参数
VOL_STRATEGY_TRADE_AMOUNT="0.1"      # 每腿数量（BTC），建议从 0.01 开始测试
VOL_STRATEGY_EXPIRY_DAYS_MIN="5"     # 最短到期天数
VOL_STRATEGY_EXPIRY_DAYS_MAX="21"    # 最长到期天数

# 风险管理
VOL_STRATEGY_TAKE_PROFIT="0.35"      # 止盈 35%
VOL_STRATEGY_STOP_LOSS="-0.40"       # 止损 -40%
VOL_STRATEGY_TRAILING_STOP="0.15"    # 移动止损 15%
VOL_STRATEGY_MAX_HOLD_DAYS="7"       # 最长持仓天数
VOL_STRATEGY_MAX_POSITIONS="3"       # 最大同时持仓数
